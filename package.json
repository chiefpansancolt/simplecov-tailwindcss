{
  "name": "simplecov-tailwind",
  "version": "1.0.2",
  "description": "HTML tailwind Design View for Simplecov formatter",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "test:start": "bundle exec rake test",
    "test:open": "open coverage/index.html",
    "test": "npm-run-all test:*",
    "markdown": "markdownlint CHANGELOG.md CODE_OF_CONDUCT.md CONTRIBUTING.md README.md -c .markdownlint.yml",
    "ruby": "rubocop",
    "javascript": "eslint dist webpack.config.js",
    "css": "stylelint dist/**/*.scss",
    "gem:build": "bundle exec rake build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chiefpansancolt/simplecov-tailwind"
  },
  "keywords": [
    "simplecov",
    "simplecov-formatter",
    "simplecov-tailwind"
  ],
  "author": {
    "name": "Christopher Pezza",
    "email": "github@chiefpansancolt.live"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chiefpansancolt/simplecov-tailwind/issues"
  },
  "contributors": [
    {
      "name": "Christopher Pezza",
      "email": "github@chiefpansancolt.live"
    }
  ],
  "homepage": "https://chiefpansancolt.live/docs/simplecov_tailwind/",
  "devDependencies": {
    "@babel/core": "^7.13.16",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/preset-env": "^7.13.15",
    "@tailwindcss/forms": "^0.3.2",
    "@tailwindcss/typography": "^0.4.0",
    "babel-loader": "^8.2.2",
    "css-loader": "^5.2.4",
    "fibers": "^5.0.0",
    "mini-css-extract-plugin": "^1.5.0",
    "postcss-loader": "^5.2.0",
    "sass": "^1.32.11",
    "sass-loader": "^11.0.1",
    "stimulus": "^2.0.0",
    "tailwindcss": "^2.1.1",
    "timeago.js": "^4.0.2",
    "webpack": "^5.35.0",
    "webpack-cli": "^4.6.0"
  }
}
